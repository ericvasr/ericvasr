# Exemplo de arquivo de ambiente para BeOnSafe
# Renomeie para .env e preencha com suas credenciais

# GitHub - Para integração com a API do GitHub
# Nota: Em ambiente GitHub Actions use o token como segredo do repositório
GITHUB_USERNAME=ericvasr
GH_TOKEN=seu_token_aqui

# API da BeOnSafe
API_BASE_URL=https://api.beonsafe.com.br
API_VERSION=v1
API_KEY=sua_chave_api
API_SECRET=seu_segredo_api

# Configurações de Agentes
AGENT_LANGUAGE=pt-br
AGENT_CONFIDENCE=0.7
AGENT_DEBUG=false

# Logs
LOG_LEVEL=info
DEBUG_MODE=false 